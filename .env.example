# Resend API key for the /contact form. Get one at https://resend.com.
# When unset, contact-form submissions are logged to the server console only.
RESEND_API_KEY=

# Where contact-form emails are sent from. Must be a verified domain in Resend.
# Until you verify a domain, you can use Resend's onboarding sender:
#   onboarding@resend.dev
CONTACT_FROM="COR Pathways <noreply@corpathway.com>"

# Where contact-form emails are delivered.
CONTACT_TO=blake.safetyconsultant@gmail.com
